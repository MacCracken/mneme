# mneme-ai tag-suggestion tests — ported 1:1 from
# rust-old/crates/mneme-ai/src/tagger.rs (4 #[test] cases).
include "src/ai_concepts.cyr"
include "src/ai_tagger.cyr"

fn _sugg_has_tag(suggs, want): i64 {
    var i = 0;
    while (i < vec_len(suggs)) {
        if (str_eq_cstr(mneme_ai_tag_suggestion_tag(vec_get(suggs, i)), want) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}
fn _all_concept_match(suggs): i64 {
    var i = 0;
    while (i < vec_len(suggs)) {
        if (mneme_ai_tag_suggestion_reason(vec_get(suggs, i)) != TAG_REASON_CONCEPT_MATCH) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn main() {
    alloc_init();
    test_group("ai_tagger");

    # suggest_from_vocabulary
    var existing = vec_new();
    vec_push(existing, str_from("rust"));
    vec_push(existing, str_from("programming"));
    vec_push(existing, str_from("python"));
    var s1 = mneme_ai_suggest_tags(str_from("Rust is a systems programming language with a borrow checker. Rust ensures memory safety without garbage collection. The Rust compiler is very strict."), existing, 5);
    assert_eq(vec_len(s1) > 0, 1, "vocab suggestions non-empty");
    assert_eq(_sugg_has_tag(s1, "rust"), 1, "suggests rust");

    # suggest_new_concepts
    var s2 = mneme_ai_suggest_tags(str_from("Machine learning algorithms require training data. Neural networks learn patterns from training examples. Deep learning extends traditional machine learning."), vec_new(), 5);
    assert_eq(vec_len(s2) > 0, 1, "new-concept suggestions non-empty");
    assert_eq(_all_concept_match(s2), 1, "all reasons ConceptMatch");

    # empty_content_error
    assert_eq(mneme_ai_suggest_tags(str_from(""), vec_new(), 5), 0, "empty content err");

    # respects_limit
    var s4 = mneme_ai_suggest_tags(str_from("Rust Go Python Java TypeScript Kotlin Swift Rust Go Python Java TypeScript Kotlin Swift Rust Go Python Java TypeScript Kotlin Swift"), vec_new(), 3);
    assert_eq(vec_len(s4) <= 3, 1, "respects limit 3");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
