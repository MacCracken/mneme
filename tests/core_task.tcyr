# mneme-core task tests — ported from rust-old/crates/mneme-core/src/task.rs.
include "src/core_uuid.cyr"
include "src/core_task.cyr"

fn main() {
    alloc_init();
    test_group("core_task");

    # extract_basic_tasks
    var id = mneme_core_uuid_v4();
    var t = mneme_core_task_extract_tasks(id, str_from("# Tasks\n- [ ] Do something\n- [x] Done thing\n- Regular item"));
    assert_eq(vec_len(t), 2, "2 tasks extracted");
    assert_eq(mneme_core_task_completed(vec_get(t, 0)), 0, "task0 not completed");
    assert_eq(mneme_core_task_completed(vec_get(t, 1)), 1, "task1 completed");
    assert(str_eq(mneme_core_task_text(vec_get(t, 0)), str_from("Do something")), "task0 text");

    # extract_priority_markers
    var t2 = mneme_core_task_extract_tasks(id, str_from("- [ ] Normal task\n- [ ] Fix bug !urgent\n- [ ] Nice to have !low"));
    assert_eq(mneme_core_task_priority(vec_get(t2, 0)), PRIO_MEDIUM, "priority medium");
    assert_eq(mneme_core_task_priority(vec_get(t2, 1)), PRIO_URGENT, "priority urgent");
    assert_eq(mneme_core_task_priority(vec_get(t2, 2)), PRIO_LOW, "priority low");

    # extract_due_dates
    var t3 = mneme_core_task_extract_tasks(id, str_from("- [ ] Submit report @2026-03-15\n- [ ] No date task"));
    assert(mneme_core_task_due_date(vec_get(t3, 0)) != (0 - 1), "task0 has due date");
    assert_eq(mneme_core_task_due_date(vec_get(t3, 1)), 0 - 1, "task1 has no due date");

    # build_board_counts
    var t4 = mneme_core_task_extract_tasks(id, str_from("- [ ] A\n- [x] B\n- [ ] C\n- [x] D"));
    var board = mneme_core_task_build_board(t4);
    assert_eq(mneme_core_board_total(board), 4, "board total");
    assert_eq(mneme_core_board_completed(board), 2, "board completed");
    assert_eq(mneme_core_board_pending(board), 2, "board pending");

    # task_serialization: priority High -> json contains "high"
    var task = mneme_core_task_new(mneme_core_uuid_v4(), mneme_core_uuid_v4(), str_from("Test"), 0, PRIO_HIGH, 0 - 1, 1);
    assert(str_contains(mneme_core_task_to_json(task), str_from("high")), "json has priority high");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
