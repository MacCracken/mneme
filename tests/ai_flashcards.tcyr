# mneme-ai flashcards tests — ported 1:1 from
# rust-old/crates/mneme-ai/src/flashcards.rs (7 #[test] cases).
include "src/core_uuid.cyr"
include "src/ai_flashcards.cyr"

fn _has(s: Str, w): i64 { if (str_index_of_cstr(s, w) >= 0) { return 1; } return 0; }
fn _ge(a, b): i64 { if (f64_le(b, a) == 1) { return 1; } return 0; }

fn main() {
    alloc_init();
    test_group("ai_flashcards");

    # extract_definition_cards
    var c1 = mneme_ai_extract_flashcards(mneme_core_uuid_v4(), str_from("**Rust**: A systems programming language focused on safety.\n**Borrow Checker**: The compiler component that enforces ownership rules."));
    assert_eq(vec_len(c1), 2, "2 definition cards");
    assert_eq(_has(mneme_ai_flashcard_front(vec_get(c1, 0)), "Rust"), 1, "card0 front has Rust");
    assert_eq(_has(mneme_ai_flashcard_back(vec_get(c1, 0)), "systems programming"), 1, "card0 back content");
    assert_eq(mneme_ai_flashcard_card_type(vec_get(c1, 0)), CARD_DEFINITION, "card0 type Definition");

    # extract_concept_cards
    var c2 = mneme_ai_extract_flashcards(mneme_core_uuid_v4(), str_from("# Title\n\n## Memory Safety\n\nRust prevents null pointer dereferences and buffer overflows.\n\n## Concurrency\n\nRust's type system prevents data races at compile time."));
    var concepts = vec_new();
    var i = 0;
    while (i < vec_len(c2)) {
        if (mneme_ai_flashcard_card_type(vec_get(c2, i)) == CARD_CONCEPT) { vec_push(concepts, vec_get(c2, i)); }
        i = i + 1;
    }
    assert_eq(vec_len(concepts), 2, "2 concept cards");
    assert_eq(_has(mneme_ai_flashcard_front(vec_get(concepts, 0)), "Memory Safety"), 1, "concept0 front");

    # sm2_good_review
    var sch = mneme_ai_card_schedule_new(mneme_core_uuid_v4());
    assert_eq(mneme_ai_card_schedule_is_due(sch), 1, "new schedule due");
    mneme_ai_card_schedule_review(sch, RECALL_GOOD);
    assert_eq(mneme_ai_card_schedule_repetitions(sch), 1, "after good reps 1");
    assert_eq(mneme_ai_card_schedule_interval_days(sch), 1, "after good interval 1");
    mneme_ai_card_schedule_review(sch, RECALL_GOOD);
    assert_eq(mneme_ai_card_schedule_repetitions(sch), 2, "after good2 reps 2");
    assert_eq(mneme_ai_card_schedule_interval_days(sch), 6, "after good2 interval 6");
    mneme_ai_card_schedule_review(sch, RECALL_GOOD);
    assert_eq(mneme_ai_card_schedule_repetitions(sch), 3, "after good3 reps 3");
    assert_eq(mneme_ai_card_schedule_interval_days(sch) > 6, 1, "after good3 interval > 6");

    # sm2_fail_resets
    var sch2 = mneme_ai_card_schedule_new(mneme_core_uuid_v4());
    mneme_ai_card_schedule_review(sch2, RECALL_GOOD);
    mneme_ai_card_schedule_review(sch2, RECALL_GOOD);
    assert_eq(mneme_ai_card_schedule_repetitions(sch2), 2, "before fail reps 2");
    mneme_ai_card_schedule_review(sch2, RECALL_AGAIN);
    assert_eq(mneme_ai_card_schedule_repetitions(sch2), 0, "after fail reps 0");
    assert_eq(mneme_ai_card_schedule_interval_days(sch2), 1, "after fail interval 1");

    # ease_factor_minimum
    var sch3 = mneme_ai_card_schedule_new(mneme_core_uuid_v4());
    var k = 0;
    while (k < 10) { mneme_ai_card_schedule_review(sch3, RECALL_HARD); k = k + 1; }
    assert_eq(_ge(mneme_ai_card_schedule_ease_factor(sch3), f64_parse("1.3")), 1, "ease >= 1.3");

    # flashcard_serialization
    var card = mneme_ai_flashcard_new(mneme_core_uuid_v4(), mneme_core_uuid_v4(), str_from("Q"), str_from("A"), CARD_DEFINITION, clock_epoch_secs());
    assert_eq(_has(mneme_ai_flashcard_to_json(card), "definition"), 1, "card json has definition");

    # no_cards_from_empty
    assert_eq(vec_len(mneme_ai_extract_flashcards(mneme_core_uuid_v4(), str_from(""))), 0, "empty no cards");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
