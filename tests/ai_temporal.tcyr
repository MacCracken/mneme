# mneme-ai temporal-analysis tests — ported 1:1 from
# rust-old/crates/mneme-ai/src/temporal.rs (5 #[test] cases).
include "src/ai_concepts.cyr"
include "src/ai_temporal.cyr"

# make_snapshot(title, content, y, m, d) — created == updated at day granularity
fn _mk(title, content, y, m, d): i64 {
    var ymd = mneme_ai_ymd(y, m, d);
    return mneme_ai_note_snapshot_new(str_from(title), str_from(content), vec_new(), ymd, ymd);
}
fn _pair(key, count): i64 {
    var p = alloc(16);
    store64(p, str_from(key));
    store64(p + 8, count);
    return p;
}

fn main() {
    alloc_init();
    test_group("ai_temporal");

    # empty_notes
    var r0 = mneme_ai_analyze_temporal(vec_new());
    assert_eq(mneme_ai_temporal_report_total_notes(r0), 0, "empty total_notes 0");
    assert_eq(mneme_ai_temporal_report_date_range(r0), 0, "empty date_range none");

    # single_note_analysis
    var n1 = vec_new();
    vec_push(n1, _mk("Test", "Hello world test content.", 2026, 3, 1));
    var r1 = mneme_ai_analyze_temporal(n1);
    assert_eq(mneme_ai_temporal_report_total_notes(r1), 1, "single total_notes 1");
    assert_eq(vec_len(mneme_ai_temporal_report_activity(r1)), 1, "single activity len 1");
    assert_eq(mneme_ai_period_activity_notes_created(vec_get(mneme_ai_temporal_report_activity(r1), 0)), 1, "single created 1");

    # multi_month_activity
    var n2 = vec_new();
    vec_push(n2, _mk("Jan Note", "January content about Rust programming Rust.", 2026, 1, 15));
    vec_push(n2, _mk("Feb Note 1", "February content about Rust systems Rust.", 2026, 2, 10));
    vec_push(n2, _mk("Feb Note 2", "More February content about Rust design Rust.", 2026, 2, 20));
    vec_push(n2, _mk("Mar Note", "March content about Python programming Python.", 2026, 3, 5));
    var r2 = mneme_ai_analyze_temporal(n2);
    assert_eq(mneme_ai_temporal_report_total_notes(r2), 4, "multi total_notes 4");
    assert_eq(vec_len(mneme_ai_temporal_report_activity(r2)), 3, "multi activity len 3");
    assert_eq(str_eq_cstr(mneme_ai_temporal_report_most_active(r2), "2026-02"), 1, "multi most active 2026-02");

    # trend_detection
    var rising = vec_new();
    vec_push(rising, _pair("2026-01", 1));
    vec_push(rising, _pair("2026-02", 2));
    vec_push(rising, _pair("2026-03", 5));
    vec_push(rising, _pair("2026-04", 10));
    assert_eq(mneme_ai_compute_trend(rising), TREND_RISING, "rising trend");
    var declining = vec_new();
    vec_push(declining, _pair("2026-01", 10));
    vec_push(declining, _pair("2026-02", 8));
    vec_push(declining, _pair("2026-03", 2));
    vec_push(declining, _pair("2026-04", 1));
    assert_eq(mneme_ai_compute_trend(declining), TREND_DECLINING, "declining trend");
    var stable = vec_new();
    vec_push(stable, _pair("2026-01", 5));
    vec_push(stable, _pair("2026-02", 5));
    vec_push(stable, _pair("2026-03", 5));
    vec_push(stable, _pair("2026-04", 5));
    assert_eq(mneme_ai_compute_trend(stable), TREND_STABLE, "stable trend");

    # report_serialization
    var rep = mneme_ai_temporal_report_new(5, mneme_ai_date_range_new(str_from("2026-01-01"), str_from("2026-03-13")), vec_new(), vec_new(), str_from("2026-02"), 150);
    assert_eq(str_index_of_cstr(mneme_ai_temporal_report_to_json(rep), "2026-02") >= 0, 1, "json contains 2026-02");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
